rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'sriramreddydwarampudi@gmail.com';
    }

    match /{allPaths=**} {
      // Allow public read for assets/product images
      allow read: if true;
      // Only admin can upload/delete
      allow write: if isAdmin();
    }
  }
}
